#!/usr/bin/env bash
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UC_DIR="$(dirname "$SHIM_DIR")"
REAL_GREP=""
IFS=:
for d in $PATH; do
  if [ -d "$d" ] && [ "$(cd "$d" && pwd)" != "$SHIM_DIR" ] && [ -x "$d/grep" ] && [ ! -d "$d/grep" ]; then
    REAL_GREP="$d/grep"
    break
  fi
done
unset IFS

if [ -z "$REAL_GREP" ]; then
  echo "grep: command not found" >&2
  exit 127
fi

"$REAL_GREP" "$@" | python3 "$UC_DIR/uc" rtk-filter "grep"
