#!/usr/bin/env bash
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UC_DIR="$(dirname "$SHIM_DIR")"
REAL_GIT=""
IFS=:
for d in $PATH; do
  if [ -d "$d" ] && [ "$(cd "$d" && pwd)" != "$SHIM_DIR" ] && [ -x "$d/git" ] && [ ! -d "$d/git" ]; then
    REAL_GIT="$d/git"
    break
  fi
done
unset IFS

if [ -z "$REAL_GIT" ]; then
  echo "git: command not found" >&2
  exit 127
fi

if [[ "$1" == "diff" || "$1" == "status" ]]; then
  "$REAL_GIT" "$@" | python3 "$UC_DIR/uc" rtk-filter "git-$1"
else
  exec "$REAL_GIT" "$@"
fi
