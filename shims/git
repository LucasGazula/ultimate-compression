#!/usr/bin/env bash
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UC_DIR="$(dirname "$SHIM_DIR")"
REAL_GIT=$(PATH=$(echo "$PATH" | sed -E "s|$SHIM_DIR:?||g") which git)

if [[ "$1" == "diff" || "$1" == "status" ]]; then
  "$REAL_GIT" "$@" | python3 "$UC_DIR/uc" rtk-filter "git-$1"
else
  exec "$REAL_GIT" "$@"
fi
