#!/usr/bin/env bash
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UC_DIR="$(dirname "$SHIM_DIR")"
REAL_LS=""
IFS=:
for d in $PATH; do
  if [ -d "$d" ] && [ "$(cd "$d" && pwd)" != "$SHIM_DIR" ] && [ -x "$d/ls" ] && [ ! -d "$d/ls" ]; then
    REAL_LS="$d/ls"
    break
  fi
done
unset IFS

if [ -z "$REAL_LS" ]; then
  echo "ls: command not found" >&2
  exit 127
fi

"$REAL_LS" "$@" | python3 "$UC_DIR/uc" rtk-filter "ls"
