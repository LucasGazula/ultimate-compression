#!/usr/bin/env bash
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UC_DIR="$(dirname "$SHIM_DIR")"
REAL_TREE=$(PATH=$(echo "$PATH" | sed -E "s|$SHIM_DIR:?||g") which tree)
if [ -x "$REAL_TREE" ]; then
  "$REAL_TREE" "$@" | python3 "$UC_DIR/uc" rtk-filter "tree"
else
  # Fallback if tree is not installed on system
  echo "tree: command not found" >&2
  exit 127
fi
