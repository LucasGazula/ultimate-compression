#!/usr/bin/env bash
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UC_DIR="$(dirname "$SHIM_DIR")"
REAL_RG=""
IFS=:
for d in $PATH; do
  if [ -d "$d" ] && [ "$(cd "$d" && pwd)" != "$SHIM_DIR" ] && [ -x "$d/rg" ] && [ ! -d "$d/rg" ]; then
    REAL_RG="$d/rg"
    break
  fi
done
unset IFS

if [ -x "$REAL_RG" ]; then
  "$REAL_RG" "$@" | python3 "$UC_DIR/uc" rtk-filter "rg"
else
  # Pass-through failure if not installed
  exit 127
fi
